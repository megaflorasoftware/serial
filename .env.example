# Database (only for cloud dbs or local libsql running on a custom port)
# DATABASE_URL='http://127.0.0.1:8080'
# DATABASE_AUTH_TOKEN=

# Authentication
# Generate a secret here: https://www.better-auth.com/docs/installation#set-environment-variables
BETTER_AUTH_SECRET=

# OAuth (optional, for custom SSO login)
# OAUTH_PROVIDER_ID=
# OAUTH_PROVIDER_NAME=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_DISCOVERY_URL=
# OAUTH_AUTHORIZATION_URL=
# OAUTH_TOKEN_URL=
# OAUTH_USER_INFO_URL=
# OAUTH_SCOPES=openid email profile
# OAUTH_PKCE=false

# Email
# Not required, but needed for functions like sending password reset emails.
SENDGRID_API_KEY=

# Integrations
INSTAPAPER_OAUTH_ID=
INSTAPAPER_OAUTH_SECRET=

# Analytics
VITE_PUBLIC_UMAMI_WEBSITE_ID=
VITE_PUBLIC_UMAMI_SRC=
