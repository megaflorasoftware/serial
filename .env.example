# Core
NEXT_PUBLIC_ROOT_URL=http://localhost:3000

# Database
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Authentication
# Generate a secret here: https://www.better-auth.com/docs/installation#set-environment-variables
BETTER_AUTH_SECRET=

# Email
# Not required, but needed for functions like sending password reset emails.
SENDGRID_API_KEY=

# Analytics
# Not required, but nice to have if you're hosting an instance with many users.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
