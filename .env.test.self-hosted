# Test environment for self-hosted E2E tests
# This file is committed to the repo — do not add real secrets

# Prevent Vite from loading the root .env file during tests
VITE_ENV_DIR=tests

# Database
DATABASE_URL=http://127.0.0.1:8082

# Auth
BETTER_AUTH_SECRET=test-secret-key-for-self-hosted-tests
BETTER_AUTH_BASE_URL=http://localhost:3001

# Self-hosted flag
VITE_PUBLIC_IS_MAIN_INSTANCE=false
