{
  "name": "serial",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build && pnpm schema:generate && pnpm schema:migrate",
    "db:studio": "drizzle-kit studio",
    "schema:generate": "drizzle-kit generate:sqlite --out src/server/db/migrations --schema src/server/db/schema.ts",
    "schema:migrate": "node --experimental-specifier-resolution=node --loader ts-node/esm src/server/db/migrate",
    "dev": "pnpm schema:generate && pnpm schema:migrate && next dev --turbopack",
    "lint": "next lint",
    "start": "next start"
  },
