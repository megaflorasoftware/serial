{
  "name": "serial",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:db": "turso dev --db-file serial.db",
    "dev:db:test:main": "turso dev --db-file serial-test-main-instance.db --port 8081",
    "dev:db:test:self-hosted": "turso dev --db-file serial-test-self-hosted.db --port 8082",
    "dev:migrate:test:main": "DATABASE_URL=http://127.0.0.1:8081 BETTER_AUTH_SECRET=test-secret-key-for-main-tests pnpm schema:migrate",
    "dev:migrate:test:self-hosted": "DATABASE_URL=http://127.0.0.1:8082 BETTER_AUTH_SECRET=test-secret-key-for-self-hosted-tests pnpm schema:migrate",
    "dev:test:main": "concurrently --kill-others \"pnpm dev:db:test:main\" \"pnpm dev:migrate:test:main && DATABASE_URL=http://127.0.0.1:8081 BETTER_AUTH_SECRET=test-secret-key-for-main-tests BETTER_AUTH_BASE_URL=http://localhost:3002 VITE_PUBLIC_IS_MAIN_INSTANCE=true vite dev --port 3002\"",
    "dev:test:self-hosted": "concurrently --kill-others \"pnpm dev:db:test:self-hosted\" \"pnpm dev:migrate:test:self-hosted && DATABASE_URL=http://127.0.0.1:8082 BETTER_AUTH_SECRET=test-secret-key-for-self-hosted-tests BETTER_AUTH_BASE_URL=http://localhost:3001 VITE_PUBLIC_IS_MAIN_INSTANCE=false vite dev --port 3001\"",
    "dev:migrate": "pnpm schema:migrate",
    "dev:atomic": "vite dev",
    "dev": "concurrently --kill-others \"pnpm dev:db\" \"pnpm dev:migrate && pnpm dev:atomic\"",
    "dev:email": "email dev --dir ./src/emails --port 4000",
    "prebuild": "pnpm typecheck && pnpm format && pnpm lint",
    "build:sw": "node --import=tsx ./scripts/generate-sw.ts",
    "build:atomic": "vite build && pnpm build:sw",
    "build": "pnpm build:atomic && pnpm schema:migrate",
    "build:local": "concurrently --kill-others \"pnpm dev:db\" \"pnpm build\"",
    "schema:generate": "drizzle-kit generate",
    "schema:migrate": "node --experimental-specifier-resolution=node --loader ts-node/esm src/server/db/migrate",
    "schema:update": "pnpm schema:generate && pnpm schema:migrate",
    "db:studio": "drizzle-kit studio",
    "db:studio:test:main": "DATABASE_URL=http://127.0.0.1:8081 drizzle-kit studio",
    "db:studio:test:self-hosted": "DATABASE_URL=http://127.0.0.1:8082 drizzle-kit studio",
    "start": "node .output/server/index.mjs",
    "start:local": "concurrently --kill-others \"pnpm dev:db\" \"pnpm start\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "precommit": "pnpm typecheck && pnpm lint:fix && pnpm format:fix && git add -u",
    "test": "concurrently \"pnpm test:main\" \"pnpm test:self-hosted\"",
    "test:main": "(lsof -ti:3002 -ti:3004 -ti:8081 2>/dev/null | xargs kill -9 2>/dev/null); sleep 1; pnpm playwright test --config playwright.main-instance.config.ts",
    "test:main:ui": "(lsof -ti:3002 -ti:3004 -ti:8081 2>/dev/null | xargs kill -9 2>/dev/null); sleep 1; pnpm playwright test --ui --config playwright.main-instance.config.ts",
    "test:headed": "(lsof -ti:3002 -ti:3004 -ti:8081 2>/dev/null | xargs kill -9 2>/dev/null); sleep 1; pnpm playwright test --headed --config playwright.main-instance.config.ts",
    "test:self-hosted": "(lsof -ti:3001 -ti:3003 -ti:8082 2>/dev/null | xargs kill -9 2>/dev/null); sleep 1; pnpm playwright test --config playwright.self-hosted.config.ts",
    "test:self-hosted:ui": "(lsof -ti:3001 -ti:3003 -ti:8082 2>/dev/null | xargs kill -9 2>/dev/null); sleep 1; pnpm playwright test --ui --config playwright.self-hosted.config.ts"
  },
